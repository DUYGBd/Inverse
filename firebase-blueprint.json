{
  "entities": {
    "Report": {
      "title": "Player Report",
      "description": "A report filed against a player for misconduct.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string", "description": "UID of the user who filed the report" },
        "reportedUsername": { "type": "string", "description": "The exact username of the player being reported" },
        "reason": { "type": "string", "description": "The reason for the report" },
        "jailDuration": { "type": "string", "description": "Suggested jail duration" },
        "message": { "type": "string", "description": "Additional message from the reporter" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created" }
      },
      "required": ["reporterId", "reportedUsername", "reason", "jailDuration", "createdAt"]
    },
    "Notification": {
      "title": "Release Notification",
      "description": "A request to be notified when the game releases.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "The email to notify" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the request was made" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of player reports"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of release notification requests"
    }
  }
}
